				{
					"name": "Import Anime from AniList",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"media_id\", jsonData.data.id);",
									"    console.log('Media imported! ID: ' + jsonData.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"externalId\": \"20\",\n  \"source\": \"anilist\",\n  \"type\": \"anime\"\n}",
							"options": {
								"raw": {
									"description": "Naruto (ID: 20 in AniList)"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/external/import",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"external",
								"import"
							]
						},
						"description": "Import anime from AniList and save to database"
					}
				},
