{
  "name": "owlist-backend",
  "version": "0.1.0",
  "description": "Owlist - Social Media Tracker Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "tsx src/scripts/seed.ts"
  },
  "keywords": [
